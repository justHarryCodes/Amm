# ── Auth ───────────────────────────────────────────────
# API_SECRET is the internal session token value (never exposed to the browser)
API_SECRET=change-me-to-a-long-random-string

# ADMIN_ADDRESS is your EVM wallet address — only this address can sign in.
# Set to your MetaMask / hardware wallet address (checksummed or lowercase, both work).
ADMIN_ADDRESS=0xYourAdminWalletAddressHere

# ── WalletConnect ───────────────────────────────────────
# Get a project ID at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── Public RPC URLs (used by browser wallet connections) ─
# These are exposed to the browser — use public/rate-limited RPCs,
# or proxy through your own endpoint if you need a paid key private.
NEXT_PUBLIC_BSC_RPC_URL=https://bsc-dataseed.binance.org/
NEXT_PUBLIC_ETH_RPC_URL=https://eth.llamarpc.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ═══════════════════════════════════════════════════════
# WALLET KEYS  — one key per chain family
# ═══════════════════════════════════════════════════════

# EVM wallet (covers BSC + Ethereum — same secp256k1 address on both chains)
BOT_PRIVATE_KEY=0xyour_evm_private_key_here

# Solana wallet (covers Solana peg + Solana bulk sender)
# Export from Phantom: Settings → Export Private Key (base58 format)
SOLANA_PRIVATE_KEY=your_base58_solana_private_key_here

# ═══════════════════════════════════════════════════════
# PEG MAINTAINER
# All token/pair addresses are configurable in the UI at runtime.
# Set them here only as startup defaults — leave blank to configure in UI.
# ═══════════════════════════════════════════════════════

PEG_CHAIN=bsc          # startup default: bsc | ethereum | solana

# BSC network
NETWORK=testnet        # mainnet | testnet
BSC_RPC_URL=https://bsc-dataseed.binance.org/
BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/

# Optional startup defaults for BSC peg (override in UI anytime)
BSC_PEG_TOKEN=
BSC_PEG_STABLE=
BSC_PEG_PAIR=
PANCAKE_ROUTER=0x10ED43C718714eb63d5aA57B78B54704E256024E

# Optional startup defaults for Ethereum peg
ETH_RPC_URL=https://eth.llamarpc.com
ETH_TOKEN_ADDRESS=
ETH_STABLE_ADDRESS=
ETH_PAIR_ADDRESS=
ETH_ROUTER_ADDRESS=0x7a250d5630B4cF539739dF2C5dAcb4c659F2488D

# Optional startup defaults for Solana peg
SOLANA_PEG_TOKEN_MINT=
# Stable mint — pick USDC or USDT (or enter any stable mint in the UI)
# USDC mainnet: EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
# USDT mainnet: Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB
SOLANA_PEG_STABLE_MINT=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
JUPITER_QUOTE_API=https://quote-api.jup.ag/v6
JUPITER_PRICE_API=https://price.jup.ag/v4

# Peg safety limits (all editable live in the UI)
TARGET_PEG=1.0
UPPER_BAND=0.02
LOWER_BAND=0.02
MAX_TRADE_SIZE_TOKENS=1000
MAX_DAILY_SPEND_USD=500
MIN_LIQUIDITY_USD=5000
COOLDOWN_SECONDS=300
SLIPPAGE_TOLERANCE=0.005

# ═══════════════════════════════════════════════════════
# BNB BULK SENDER
# Token address is entered in the UI per-send — no env var needed.
# ═══════════════════════════════════════════════════════
MULTISENDER_ADDRESS=0xfc13372d4747Bbf846a8ADd351aF32E0Be956836

# ═══════════════════════════════════════════════════════
# SOLANA BULK SENDER
# ═══════════════════════════════════════════════════════
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
# Production: SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key

SOLANA_BATCH_SIZE=10
SOLANA_CONCURRENCY=3
SOLANA_PRIORITY_FEE=2000
SOLANA_MAX_RETRIES=3
SOLANA_CONFIRM_TIMEOUT=60

# ═══════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════
DATABASE_URL=postgresql://user:password@localhost:5432/pegmaintainer
